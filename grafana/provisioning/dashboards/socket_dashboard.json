{
  "title": "Socket Security Value Dashboard",
  "description": "Time-series security metrics powered by Socket.dev API",
  "tags": ["socket", "security", "supply-chain"],
  "timezone": "browser",
  "refresh": "5m",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Overall Security Score (Org Avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT collected_at AS time, avg_overall AS \"Overall\", avg_supply_chain AS \"Supply Chain\", avg_vulnerability AS \"Vulnerability\", avg_quality AS \"Quality\", avg_maintenance AS \"Maintenance\" FROM org_scores WHERE $__timeFilter(collected_at) ORDER BY collected_at",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "title": "Total Packages Monitored",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT NOW() AS time, total_packages AS \"Packages\" FROM org_scores ORDER BY collected_at DESC LIMIT 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } } }
    },
    {
      "id": 3,
      "title": "High Risk Packages",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT NOW() AS time, total_high_risk AS \"High Risk\" FROM dependency_inventory ORDER BY collected_at DESC LIMIT 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 4,
      "title": "Open CVEs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT NOW() AS time, COUNT(DISTINCT cve_id) AS \"CVEs\" FROM cve_findings WHERE $__timeFilter(collected_at)",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "id": 5,
      "title": "Alert Severity Trend",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT date_trunc('hour', collected_at) AS time, severity, SUM(count) AS count FROM alert_counts WHERE $__timeFilter(collected_at) GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": { "stacking": "normal", "legend": { "displayMode": "list" } },
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "high" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "medium" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "low" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 6,
      "title": "Bottom 10 Packages by Supply Chain Score",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT package_name, ecosystem, ROUND(CAST(score_supply_chain AS numeric), 3) AS supply_chain, ROUND(CAST(score_vulnerability AS numeric), 3) AS vulnerability, ROUND(CAST(score_overall AS numeric), 3) AS overall FROM package_scores WHERE collected_at = (SELECT MAX(collected_at) FROM package_scores) AND score_supply_chain IS NOT NULL ORDER BY score_supply_chain ASC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": { "sortBy": [{ "displayName": "supply_chain", "desc": false }] },
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "supply_chain" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] } }] }
        ]
      }
    },
    {
      "id": 7,
      "title": "CVE Findings (CVSS Score)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT package_name, cve_id, ROUND(CAST(cvss_score AS numeric), 1) AS cvss, severity, CASE WHEN is_fixable THEN '✓ Fix Available' ELSE '✗ No Fix' END AS fixable, collected_at AS \"detected\" FROM cve_findings WHERE $__timeFilter(collected_at) ORDER BY cvss_score DESC NULLS LAST LIMIT 25",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "cvss" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "steps": [{ "color": "yellow", "value": 4 }, { "color": "orange", "value": 7 }, { "color": "red", "value": 9 }] } }] },
          { "matcher": { "id": "byName", "options": "fixable" }, "properties": [{ "id": "custom.displayMode", "value": "color-text" }, { "id": "mappings", "value": [{ "type": "value", "options": { "✓ Fix Available": { "color": "green" }, "✗ No Fix": { "color": "red" } } }] }] }
        ]
      }
    },
    {
      "id": 8,
      "title": "Dependency Health Inventory",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "postgres" },
          "rawSql": "SELECT NOW() AS time, total_direct AS \"Direct Deps\", total_transitive AS \"Transitive Deps\", total_unmaintained AS \"Unmaintained\", total_deprecated AS \"Deprecated\", total_high_risk AS \"High Risk\" FROM dependency_inventory ORDER BY collected_at DESC LIMIT 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "min": 0, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } } }
    }
  ],
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
